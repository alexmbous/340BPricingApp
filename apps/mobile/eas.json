{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      },
      "ios": { "simulator": true },
      "channel": "development"
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "staging"
      },
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "android": {
        "autoIncrement": "versionCode",
        "buildType": "app-bundle"
      },
      "channel": "staging"
    },
    "production": {
      "env": {
        "APP_ENV": "production"
      },
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "android": {
        "autoIncrement": "versionCode",
        "buildType": "app-bundle"
      },
      "channel": "production"
    }
  },
  "submit": {
    "staging": {
      "ios": {
        "appleId": "REPLACE_ME",
        "ascAppId": "REPLACE_ME",
        "appleTeamId": "REPLACE_ME"
      },
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "appleId": "REPLACE_ME",
        "ascAppId": "REPLACE_ME",
        "appleTeamId": "REPLACE_ME"
      },
      "android": {
        "track": "production"
      }
    }
  }
}
