NODE_ENV=development
PORT=4000

# Postgres connection — matches docker-compose.yml defaults
DATABASE_URL=postgresql://apexcare:apexcare_dev_only@localhost:5432/apexcare_dev?schema=public

# Auth — HS256 for v1 (single service). Rotate when deploying.
# Generate strong values: `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string-at-least-64-bytes-1234567890
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string-for-refresh-tokens-abc
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Providers: "mock" for local dev. Future: "live" or per-provider config.
PROVIDERS_MODE=mock

# CORS: comma-separated origins allowed to hit the API
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:19000

# Logging
LOG_LEVEL=debug

# Audit
# If true, Postgres will reject UPDATE/DELETE on audit_log (applied via migration).
AUDIT_ENFORCE_APPEND_ONLY=true
