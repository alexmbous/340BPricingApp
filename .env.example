# ─────────────────────────────────────────────────────────────
# Root-level shared env. Per-app env lives in apps/*/.env.example
# Copy to .env for local development.
# ─────────────────────────────────────────────────────────────
NODE_ENV=development

# Postgres (used by docker compose and apps/api)
POSTGRES_USER=apexcare
POSTGRES_PASSWORD=apexcare_dev_only
POSTGRES_DB=apexcare_dev
POSTGRES_PORT=5432
