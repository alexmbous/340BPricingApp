{
  "name": "apexcare-340b-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "pnpm --filter @apexcare/api prisma migrate reset --force",
    "db:migrate": "pnpm --filter @apexcare/api prisma migrate dev",
    "db:seed": "pnpm --filter @apexcare/api db:seed",
    "api:dev": "pnpm --filter @apexcare/api dev",
    "mobile:dev": "pnpm --filter @apexcare/mobile dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "typescript": "5.4.5",
    "prettier": "3.3.3",
    "@types/node": "20.12.12"
  }
}
